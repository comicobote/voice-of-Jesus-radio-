{
  "entities": {
    "settings": {
      "title": "Settings",
      "description": "App configuration parameters and credentials",
      "type": "object",
      "properties": {
        "secret_key": {
          "type": "string",
          "description": "Flutterwave API secret key"
        },
        "public_key": {
          "type": "string",
          "description": "Flutterwave API public key"
        }
      },
      "required": ["secret_key"]
    },
    "campaign": {
      "title": "Campaign",
      "description": "Radio live campaign tracking",
      "type": "object",
      "properties": {
        "total_received_ugx": {
          "type": "number",
          "description": "Total amount in UGX received from believers so far"
        },
        "target_ugx": {
          "type": "number",
          "description": "Goal target amount in UGX"
        }
      },
      "required": ["total_received_ugx", "target_ugx"]
    },
    "donation": {
      "title": "Donation",
      "description": "An individual completed or pending mobile money support contribution",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Donor's display name"
        },
        "amount": {
          "type": "number",
          "description": "Amount in UGX contributed"
        },
        "email": {
          "type": "string",
          "description": "Donor's contact email"
        },
        "phone": {
          "type": "string",
          "description": "Donor's phone number"
        },
        "provider": {
          "type": "string",
          "description": "Mobile Money network provider"
        },
        "note": {
          "type": "string",
          "description": "A customized prayer or message of support"
        },
        "tx_ref": {
          "type": "string",
          "description": "Unique transaction reference string"
        },
        "status": {
          "type": "string",
          "description": "Donation state"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Date and time transaction was recorded"
        }
      },
      "required": ["name", "amount", "tx_ref", "status"]
    },
    "blog": {
      "title": "Blog",
      "description": "Gospel blog post or announcement created by administrator",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Blog Title text"
        },
        "content": {
          "type": "string",
          "description": "Blog markdown or plain content text"
        },
        "category": {
          "type": "string",
          "description": "Category for classification"
        },
        "author": {
          "type": "string",
          "description": "Name of the writer"
        },
        "date": {
          "type": "string",
          "description": "Display format date string"
        },
        "imageUrl": {
          "type": "string",
          "description": "Optional illustration image URL"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Document timestamp"
        }
      },
      "required": ["title", "content", "date"]
    }
  },
  "firestore": {
    "/settings/{settingsId}": {
      "schema": "settings",
      "description": "Configuration metadata"
    },
    "/campaign/{campaignId}": {
      "schema": "campaign",
      "description": "Goal progression tracking data"
    },
    "/donations/{donationId}": {
      "schema": "donation",
      "description": "Completed or pending mobile money support list"
    },
    "/blogs/{blogId}": {
      "schema": "blog",
      "description": "Gospel radio news feeds and administrative articles"
    }
  }
}
